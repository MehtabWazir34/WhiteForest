PORT=5000\nJWT_SECRET=secret\nMONGO_URI=mongodb://localhost:27017/whiteforest
# ===========================================
# WHITE FOREST BACKEND - ENVIRONMENT VARIABLES
# ===========================================

# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/white_forest

# Frontend
CLIENT_URL=http://localhost:5173

# JWT (Admin Only)
JWT_SECRET=change_this_super_secret_admin_jwt_key
JWT_EXPIRES_IN=7d

# Guest Token
GUEST_TOKEN_SECRET=change_this_super_secret_guest_token_key
GUEST_TOKEN_EXPIRES_IN=30d

# Cookies
COOKIE_SECRET=change_this_super_secret_cookie_key

# Booking Rules
CANCELLATION_WINDOW_MINUTES=20
DEFAULT_ADVANCE_PAYMENT_PERCENT=30
BOOKING_REFERENCE_PREFIX=WF
FOOD_ORDER_REFERENCE_PREFIX=FO

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Payment Gateways - Phase 2 (fill in when enabling)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email (Invoices / Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=White Forest Hotel <no-reply@whiteforest.com>

# Hotel Info (used in Invoice generation)
HOTEL_NAME=White Forest Hotel
HOTEL_ADDRESS=Murree, Punjab, Pakistan
HOTEL_PHONE=+92-300-0000000
HOTEL_EMAIL=info@whiteforest.com
